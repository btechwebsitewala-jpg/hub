<!-- show login popup -->
<div class="modal fade _showLoginPopup_" id="showLoginPopup" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">
                <div class="logitio">
                    <button type="button" class="btn-close btn" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="login-card">
                    <!-- Login Section -->
                    <div class="_login_number_divsd">
                        <h3 class="heading-small">Sign In/Sign Up to Continue</h3>
                        <p>We’ll confirm your booking shortly! <br>Please provide your number to receive updates.
                        </p>
                        <div class="input-section">
                            <input type="text" id="otp_number" name="otp_number" placeholder="Enter Your Mobile" 
                                   class="number _otp_number form-control" maxlength="10" minlength="10">
                                 
   <div class="form-check">
   <input class="form-check-input m-0 checks" name="whatsapp_status" type="checkbox" value=""  checked> 
  <label class="form-check-label" for="flexCheckDefault">
I authorize Pathkind Labs and its affiliates/ representatives to contact me via phone calls, email, RCS, SMS or WhatsApp.  </label>
</div>


                            <button type="button" class="custom-form-btn btn otp_submittingBookings_" id="submitBooking"> 
                                Generate OTP
                            </button>
                        </div>
                        <small>
                            By proceeding, you agree to Pathkind<br>
                            <a href="https://www.pathkindlabs.com/terms-use">T&C</a> and <a href="https://www.pathkindlabs.com/privacy-policy">Privacy Policy</a>.
                        </small>
                    </div>

                    <!-- OTP Verification Section -->
                    <div class="_verfy_otp_divsd" style="display:none;">
                        <div class="cards">
                            <h3 class="heading-small">OTP Verification</h3>
                            <p class="mobile-number">
                                Enter the 6-digit verification code we just sent you to 
                                <span class="entered_phone_no"></span> through SMS. 
                                <span class="_chngeMobile d-none">Change Mobile</span>
                            </p>
                            <div class="d-flex gp">
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                                <div class="otp-input">
                                    <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                                </div>
                            </div>
                            <div class="otp_error"></div>
                            <div class="otpgrop">
                                <button type="submit" class="next-btn" id="submitBookingOTP">
                                    Verify and Proceed
                                </button>
                                <span class="_resent_otp resend-otp-link" style="display:none">Resend OTP</span>
                            </div>
                            <span class="resent_otp_d resend-otp-text">
                                Time Remaining: <span class="timerCount" id="stop-timer">20</span> seconds
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End login Pop -->

