<style>
    p.order-updatedMessage {
    line-height: normal !important;
}
.basket-card {
    position: absolute;
    top: 0px;
    right: 0px;
    width: 320px;
    background: #fff;
    border: 1px solid #848282;
    border-radius: 8px;
    padding: 15px;
    z-index: 9999;
}
.container.rel {
    position: relative;
}
a.remove-from-cart.checkout-btn {
    text-align: center !important;
}
.basket-item .price_rate .d-flex.w-100 + .d-flex.w-100.align-items-center + .icon_section {
    display: none;
}
.basket-item .price_rate .d-flex.w-100 + .d-flex.w-100.align-items-center {
    display: none !important;
}
.side-bar-cart-list {
    width: 100%;
}
/* Arrow */
.basket-card::after {
    content: "";
    position: absolute;
    top: -10px;
    right: 20px;
    width: 15px;
    height: 15px;
    background: #fff;
    border-left: 1px solid #848282;
    border-top: 1px solid #848282;
    transform: rotate(45deg);
}

/* Header */
.basket-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: 18px;
}

.basket-title {
    display: flex;
    align-items: center;
    gap: 8px;
      font-size: 15px;
}

.basket-title i {
    font-size: 18px;
}

.item-count {
    font-size: 13px;
    color: #777;
}

/* Item */
.basket-item {
    margin-top: 15px;
    font-size: 14px;
}

.item-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
}
#basketBox .rates {
    display: none !important;
}
.basket-item .price_rate {
    background: #ffff!important;
    padding: 0px!important;
}
.item-name {
    font-weight: 500;
}

.item-price {
    font-weight: 600;
}

.item-sub {
    margin-top: 5px;
    color: #777;
    font-size: 13px;
}

/* Delete */
.delete-btn {
    cursor: pointer;
    color: #000;
}

/* Divider */
.divider {
    border: none;
    border-top: 1px solid #000;
    margin: 15px 0;
}

/* Total */
.total-row {
    display: flex;
    justify-content:start;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 15px;
     margin-top: 15px;
}
#basketBox span._grand_Total:before {
    content: "₹"; 
}

.col-lg-4._payment_detail_sec_ span._grand_Total:before {
    display: none;
}

.col-lg-4._payment_detail_sec_ span._grand_Total {
    margin-left: 0;
 }
span._grand_Total {
    margin-left: 108px;
    display: inline-block;
}
span._grand_Total:before {
    content: "₹";
    margin-right: 1px;
} 
.basket-header .cart-badge span {
    position: relative;
    top: 1px;
}
.basket-header span.cart-badge {
    position: static;
    background: none;
}
/* Button */
.checkout-btn {
    width: 100%;
    background: #0a9d3c;
    color: #fff;
    border: none;
    padding: 12px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 5px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.item-count span.cart-badge {
    background: none;
}
.item-count span.cart-badge {
    background: none;
    display: flex !important;
    gap: 3px;
    align-items: center;
}
.item-count .cart-badge span {
    position: relative;
    top: 0px;
}
.basket-item .price_rate span {
    font-size: 12px;
    display: block;
}
.basket-item  ._item_m_p {
    display: flex;
}
.basket-item  ._test_package_name {
    width: 160px;
    text-overflow: ellipsis;
}
#removeItemModal, #successModal, #successModalpatient {z-index: 99999;}  
#removeItemModal .modal-dialog.modal-dialog-centered.modal-sm , #successModal .modal-dialog.modal-dialog-centered.modal-sm, #successModalpatient .modal-dialog.modal-dialog-centered.modal-sm{
    max-width: 421px;
    margin: 1.75rem auto;
}
#removeItemModal button.btn-close.btn-close-white, #successModal button.btn-close.btn-close-white, #successModalpatient button.btn-close.btn-close-white {
    background-color: transparent;
    right: 10px;
    top: 10px;
    filter: brightness(0.5);
} 
#removeItemModal .modal-header.bg-danger.text-white.py-2, #successModal .modal-header.bg-success.text-white.py-2, #successModalpatient .modal-header.bg-success.text-white.py-2 {
    background: transparent !important;
    border: none;
}
#successModal .modal-footer, #removeItemModal .modal-footer,  #successModalpatient .modal-footer {
    flex-wrap: nowrap; 
    justify-content: center;
}
#successModal .modal-footer button, 
#removeItemModal .modal-footer button, 
#successModal .modal-footer a, 
#removeItemModal .modal-footer a, 
#successModalpatient .modal-footer a, 
#successModalpatient .modal-footer button{
    width: auto;
    padding: 10px 29px;
    border-radius: 79px;
    background: #0a1b29;
}
#successModal svg, #removeItemModal svg,  #successModalpatient svg{
    margin-bottom: 15px;
}
i.fa.fa-cloud-download {
    font-size: 20px;
    float: left;
    margin-left: 0px;
}
 ._cart_item_list:first-child .cart_item_row .price_rate {
    background: #fff8e0;
}
.basket-card{
    background: #fff8e0;
}
.basket-item .price_rate {
    background: transparent !important;
    padding: 0px!important;
}
#trackingDetailsModal .modal-header {
    background: #194569;
    color: #ffff;
    padding: 0.5rem 1rem;
}
#trackingDetailsModal a.btn.btn-dark.w-100{
      background: #194569;
         border-radius: 20px;
}

##trackingDetailsModal .modal-dialog {
    max-width: 620px;
}

div#visitNotFoundModal .modal-dialog {
    max-width: 330px;}
#trackingDetailsModal .modal-content {
    overflow: hidden;
    border-radius: 18px;
    border: none;
}
#trackingDetailsModal .modal-header .btn-close {
    opacity: 1;
    filter: invert(1);
        top: 10px;
    right: 10px;
    background: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23000'%3e%3cpath d='M.293.293a1 1 0 011.414 0L8 6.586 14.293.293a1 1 0 111.414 1.414L9.414 8l6.293 6.293a1 1 0 01-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 01-1.414-1.414L6.586 8 .293 1.707a1 1 0 010-1.414z'/%3e%3c/svg%3e")center/1em auto no-repeat !important;
}

#trackingDetailsModal .modal-content {
    background: none;
}
#trackingDetailsBody {
    background: #fff;
} 
div#trackingDetailsBody, div#visitNotFoundModal  {
    font-size: 14px;
}
#trackingDetailsBody .modal-title{
    font-size: 16px;
}
div#visitNotFoundModal .modal-content {
    overflow: hidden;
    border-radius: 18px;
    border: none;
}
div#visitNotFoundModal button.btn.btn-outline-dark.w-50, div#visitNotFoundModal a{
    border-radius: 20px;
      background: #194569;
      color:  #fff; 
      border: solid 1px  #194569;
}

 div#trackingDetailsBody h5 {
    font-size: 16px;
}
 div#visitNotFoundModal h5 {
    font-size: 16px;
} 
#trackingDetailsModal .modal-dialog.modal-dialog-centered.modal-lg {
    max-width: 500px;
}
button#submitBookingOTP_track {
    margin-left: 0px;
    margin-bottom: 0px;
    background: #194569;
    text-decoration: none;
    color: #fff;
    padding: 8px 25px !important;
    width: 100%;
    margin-top: 10px;
    font-size: 13px;
    border-radius: 25px;
    font-weight: 600;
    border: 0;
}
</style>
</style>

