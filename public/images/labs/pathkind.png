    height: 30px;
    margin-right: 50px;
}
span.users4 {
    display: block;
    width: 35px;
    white-space: nowrap;
    overflow: hidden;
    background: #194569;
    text-align: center;
    border-radius: 30px;
    height: 35px;
    text-indent: 10px;
    line-height: 38px;
    margin-bottom: 0px;
}
.side-login-inner, .sidebar-inner {
    width: 340px;
} 
.useremail span {
    display: block;
