<script>
    var slugCityName = 'gurugram';
    var thankyouPageUrl = {
        "health-checkups-sp": "thank-you-sp",
        "health-checkups-af": "thank-you-af",
        "health-checkups-af": "thank-you-af",
        "health-checkups": "thank-you-hcp",
        "book-home-collection": "",
        "know-about-covid-19": "book-a-test/" + slugCityName,
        "drivethru": "",
        "franchise-business-opportunities": "thank-you",
        "contact-us": "thank-you",
        "hospital-lab-management": "thank-you", 
        "radiology": "radiology-thank-you",
        "health-packages": "health-packages-thank-you",
        "upload-prescription": "",
        "nabl": "thank-you" 
    };
    var formIdByPageNameWithPageUrl = {
        "book-home-collection": "Home Collection Form",
        "contact-us": "Contact Us",
        "franchise-business-opportunities": "Franchise Business Opportunities",
        "upload-prescription": "Upload Prescription",
        "hospital-lab-management": "Hospital Lab Management",
        "annual-corporate-wellness-program": "Annual Corporate Wellness Program",
        "organise-free-health-check-up-camps": "Organise Free Health Check Up Camps",
        "contact-us": "thank-you",

    }; 
    $(document).ready(function ($) {

        /**
         * Home Page Form Validation 
         */
        $('#otpFormSubmit').validate({
            rules: {
                name: {
                    required: true,
                    minlength: 3,
                },
                mobile_no: {
                    required: true,
                    digits: true,
                    minlength: 10,
                    maxlength: 10,
                },
                email: {
                    required: true,
                    email: true,
                },
                // city: {
                //     required: true,
                // },
            },
            messages: {
                name: {
                    required: "Name is required.",
                    minlength: "Name must be at least 3 characters long.",
                },
                mobile_no: {
                    required: "Mobile number is required.",
                    digits: "Only numeric values are allowed.",
                    minlength: "Mobile number must be 10 digits.",
                    maxlength: "Mobile number must be 10 digits.",
                },
                email: {
                    required: "Email is required.",
                    email: "Please enter a valid email address.",
                },
                // city: {
                //     required: "City is required.",
                // },
            },
            errorElement: 'div',
            errorClass: 'error-class', // Add error-alert class for consistency
            submitHandler: function (form) {

                /** Check upload prescription file */
                let form_id = $(form).find('input[name="form_id"]').val();

                // This function is called when the form is valid
                $(form).find('input[type="submit"]').prop('disabled', true);

                // Collect form data
                var name = $('#otpFormSubmit').find('input[name=name]').val();
                var mobile = $('#otpFormSubmit').find('input[name=mobile_no]').val();
                var city = $('#otpFormSubmit').find('input[name=city]').val();
                var whatsapp = $('#otpFormSubmit').find('input[name=whatsapp_status]').is(":checked") ? 1 : 0;

                if (!city) {
                    city = $('#otpFormSubmit').find('#radiologyCity').val();
                }
                var email = $('#otpFormSubmit').find('input[name=email]').val();

                if (form_id === 'upload-prescription') {
                    let file = $('#edit-upload-file');
                    var files = file[0].files;

                    // Allowed file types and max size (5MB)
                    const allowedExtensions = ['.doc', '.pdf', '.jpeg', '.jpg', '.png'];
                    const maxFileSize = 5 * 1024 * 1024; // 5 MB

                    // Check if a file is selected
                    if (files.length > 0) {
                        const selectedFile = files[0];
                        const fileName = selectedFile.name.toLowerCase();
                        const fileExtension = fileName.slice(fileName.lastIndexOf('.'));

                        // Clear previous errors
                        $('.error_class').remove();

                        // Validate file type
                        if (!allowedExtensions.includes(fileExtension)) {
                            $(file).after('<div class="error_class">Invalid file type. Only .doc, .pdf, .jpeg, .jpg, and .png are allowed.</div>');
                            $(form).find('input[type="submit"]').prop('disabled', false);
                            return false;
                        }

                        // Validate file size
                        if (selectedFile.size > maxFileSize) {
                            $(file).after('<div class="error_class">File size exceeds 5 MB. Please upload a smaller file.</div>');
                            $(form).find('input[type="submit"]').prop('disabled', false);
                            return false;
                        }
                    } else {
                        $(form).find('input[type="submit"]').prop('disabled', true);
                    }
                }

                var jsonData = {
                    "url": "https://www.pathkindlabs.com/api/v1/home-collection-booking/resend-otp",
                    "params": {
                        "name": name,
                        "mobile": mobile,
                        "email": email ? email : '',
                        "city_id": city,
                        "whatsapp_status": whatsapp,
                    }
                };

                console.log(jsonData);
                sendOtp(form, jsonData);
            }
        });
        $('#verifyOtp').submit(function () {
            $('.error-alert').remove();
            var e = this;
            var name = $('#otpFormSubmit').find('input[name=name]').val();
            var mobile = $('#otpFormSubmit').find('input[name="mobile_no"]').val();
            var city = $('#otpFormSubmit').find('input[name="city"]').val();
            if (!city) {
                var city = $('#otpFormSubmit').find('#radiologyCity').val();
            }
            var email = $('#otpFormSubmit').find('input[name="email"]').val();
            var form_id = $('#otpFormSubmit').find('input[name="form_id"]').val();
            var whatsapp = $('#otpFormSubmit').find('input[name=whatsapp_status]').is(":checked") ? 1 : 0;
            var otp = $(e).find('input[name="otp[]"]');
            var otpArr = [];
            var otpError = false
            if (otp.length == 6) {
                otp.each(function (index, data) {

                    var oV = $(this).val();
                    if (!oV) {
                        otpError = true;
                    }
                    otpArr.push(oV);
                });
            }
            if (!mobile) {
                $(e).prepend(`<div class="error-alert" id="msg-alert">Mobile number is invalid.</div>`);
                $('html, body').animate({
                    scrollTop: $(e).offset().top - 200
                }, 1000);
                // setTimeout(function() {
                //     window.location.reload();
                // }, 1500);
            }
            if (otpError) {
                $(e).prepend(`<div class="error-alert">Mobile number is invalid.</div>`);
                $('html, body').animate({
                    scrollTop: $(e).offset().top - 200
                }, 1000);
            }
            if (!mobile && otpError) {
                console.log('invalid validateForms');
                return false;
            } else {
                console.log('ready');
                $(e).find('input[type=submit]').prop('disabled', true);
                var mobile = mobile;
                var otp = otpArr.join();
                otp = otp.replace(/,/g, '');
                var jsonData = {
                    // "url": "https://abym.in/dev-url/pk/verifyOtp.php",

                    // "url": "http://20.204.156.193/api/v1/home-collection-booking/verify-otp2", 
                    // "url": BASEURL + "/api/v1/home-collection-booking/verify-otp2",
                    "url": BASEURL + "api/v1/home-collection-booking/verify-otp",
                    "params": {
                        "otp": otp,
                        "mobile": mobile,
                        "form_id": form_id,
                        "name": name,
                        "city": city,
                        "email": email ? email : "",
                        "whatsapp_status": whatsapp,
                    }
                }
                verifyOtp(e, jsonData);
            }
            return false;
        });
        $('#without-otp').submit(function () {
            var e = this;
            var res = validateForms(e);
            if (!res) {
                console.log('invalid validateForms', res);
                return false;
            } else {
                console.log('ready 2');
                var name = $('#without-otp').find('input[name=name]').val();
                var mobile = $('#without-otp').find('input[name=mobile_no]').val();
                var city = $('#without-otp').find('input[name=city]').val();
                var webformid = $('#without-otp').find('input[name=form_id]').val();
                var whatsapp = $('#without-otp').find('input[name=whatsapp_status]').is(":checked") ? 1 : 0;
                var jsonData = {
                    "url": "https://www.pathkindlabs.com/auth/webform/submit",
                    "params": {
                        "Name": name,
                        "MobileNo": mobile,
                        "City": city,
                        "whatsapp_status": whatsapp,
                        "UTM_Source": findGetParameter('utm_source'),
                        "UTM_Medium": findGetParameter('utm_medium'),
                        "CampaignID": findGetParameter('utm_campaign'),
                        "LeadUrl": window.location.href,
                        "CampaignName": '',
                        "ci_csrf_token": "",
                    }
                }
                sendAjax(e, jsonData, webformid);
            }
            return false;
        });
        $('#drivThruForm').submit(function () {
            var e = this;
            var res = validateForms(e);
            if (!res) {
                console.log('Invalid');
                return false;
            } else {
                $('#msg-alert').remove();
                var webformid = $(e).find('input[name=form_id]').val();
                var drive_thru_in = $(e).find('input[name=drive_thru_in]').val();
                var patient_name = $(e).find('input[name=patient_name]').val();
                var date_of_birth = $(e).find('input[name=date_of_birth]').val();
                var gender = $(e).find('input[name=gender]').val();
                var email = $(e).find('input[name=email]').val();
                var whatsapp_status = $(e).find('input[name=whatsapp_status]').val();
                var mobile_no = $(e).find('input[name=mobile_no]').val();
                var current_address = $(e).find('input[name=current_address]').val();
                var valid_id_proof_path = $(e).find('input[name=valid_id_proof_path]').val();
                var valid_address_proof_path = $(e).find('input[name=valid_address_proof_path]').val();
                var slot_date = $(e).find('input[name=slot_date]').val();
                var slot_time = $(e).find('input[name=slot_time]').val();
                var captcha_response = $(e).find('input[name=captcha_response]').val();
                var jsonData = {
                    "url": "https://www.pathkindlabs.com/auth/webform/drivethru/submit",
                    "params": {
                        // "Name": name,
                        "MobileNo": mobile_no,
                        "DriveThruIn": drive_thru_in,
                        "PatientName": patient_name,
                        "DateOfBirth": date_of_birth,
                        "Gender": gender,
                        "Email": email,
                        "whatsapp_status": whatsapp_status,
                        "CurrentAddress": current_address,
                        "ValidIdProofPath": valid_id_proof_path,
                        "ValidAddressProofPath": valid_address_proof_path,
                        "SlotDate": slot_date,
                        "SlotTime": slot_time,
                        "UTM_Source": findGetParameter('utm_source'),
                        "UTM_Medium": findGetParameter('utm_medium'),
                        "CampaignID": findGetParameter('utm_campaign'),
                        "captcha_response": captcha_response,
                        "ci_csrf_token": "",
                    }
                }
                sendAjax(e, jsonData, webformid);
            }
            return false;
        });
        $('input.number').on('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '').replace(/(\..*)\./g, '$1');
        });
    });

    function verifyOtp(e, data) {
        var raw = data.params;
        const payload = {
            body: raw,
            url: data.url,
            authorization: ""
        }
        const headerData = generateHeaders(payload);
        headers = {};
        headers[`x${_api_token}`] = headerData[`x${_api_token}`];
        headers[`auth${_nonce}`] = headerData[`auth${_nonce}`];
        headers[`auth${_signature}`] = headerData[`auth${_signature}`];
        headers[`authorization`] = getCookie('authorization_token');
        if (e && data.url && data.params.mobile) {
            var raw = data.params;

            var settings = {
                "url": data.url,
                "method": "POST",
                "headers": headers,
                "data": raw
            };
            $.ajax(settings).done(function (response) {
                var res = response; //JSON.parse(response);
                if (res.status == 200) {
                    console.log('DONE');
                    console.log('Genrate lead');

                    successHandler(e, data, res?.data);
                    // $('.otp-form').fadeOut(0);
                    // $('#otpFormSubmit').fadeIn(0);
                    // $('#otpFormSubmit').find('input').not('input[type=submit]').val('');
                    // $('#otpFormSubmit').find('input[type=submit]').prop('disabled', false);
                } else {
                    if (typeof res.message != undefined) {
                        var msg = res.message;
                    } else {
                        var msg = 'Something went wrong try again.';
                    }
                    $(e).find('input[type=submit]').prop('disabled', false);
                    $(e).prepend(`<div class="error-alert" id="msg-alert">` + msg + `</div>`);
                    $('html, body').animate({
                        scrollTop: $(e).offset().top - 200
                    }, 1000);
                }
            }).fail(function (errorobj, textstatus, error, exception) {
                // console.log('error', error);
                // console.log('errorobj', errorobj);
                var msg = errorobj?.responseJSON?.message || 'Something went wrong try again.';
                $(e).prepend(`<div class="error-alert" id="msg-alert">` + msg + `</div>`);
                $('html, body').animate({
                    scrollTop: $(e).offset().top - 200
                }, 1000);

                $(e).find('input[type="submit"]').prop('disabled', false);
                erroHandling(errorobj, textstatus, error, exception);

            });;
        }
    }

    function sendOtp(e, data) {
        try {
            var raw = data.params;
            const payload = {
                body: raw,
                url: data.url,
                authorization: ""
            }
            const headerData = generateHeaders(payload);
            headers = {};
            headers[`x${_api_token}`] = headerData[`x${_api_token}`];
            headers[`auth${_nonce}`] = headerData[`auth${_nonce}`];
            headers[`auth${_signature}`] = headerData[`auth${_signature}`];
            headers[`authorization`] = getCookie('authorization_token');
            if (e && data.url && data.params.mobile) {
                var settings = {
                    "url": data.url,
                    "method": "POST",
                    "headers": headers,
                    "data": raw
                };
                $.ajax(settings)
                    .done(function (response) {
                        var res = response; //JSON.parse(response);
                        if (res.status == 200) {
                            $(e).fadeOut(0);
                            $('.otp-form').fadeIn(0);

                            $("#stop-timer").prop("id", "timer_id_");
                            $("#timer").text("0:59");
                            startTimer();
                        } else {
                            $(e).find('input[type=submit]').prop('disabled', false);
                            $(e).prepend(`<div class="error-alert" id="msg-alert">Something went wrong try again.</div>`);
                            $('html, body').animate({
                                scrollTop: $(e).offset().top - 200
                            }, 1000);
                        }
                    })
                    .fail(function (errorobj, textstatus, error, exception) {
                        $(e).find('input[type="submit"]').prop('disabled', false);
                        erroHandling(errorobj, textstatus, error, exception);
                    });
            } else {
                $(e).find('input[type=submit]').prop('disabled', false);
                $(e).prepend(`<div class="error-alert" id="msg-alert">Enter your mobile number.</div>`);
                $('html, body').animate({
                    scrollTop: $(e).offset().top - 200
                }, 1000);
            }
        } catch (error) {
            console.error('sendOtp', error);
        }
    }
    $('.change-mobile-no-home').click(function () {
        // $('.otp-form').fadeOut(0);
        // $('#otpFormSubmit').fadeIn(0);
        // $('#otpFormSubmit').find('input').not('input[type=submit]').val('');
        // $('#otpFormSubmit').find('input[type=submit]').prop('disabled', false);
        window.location.reload();
    });

    function register(e, jsonData) {
        if (jsonData.params.mobile) {
            var data = {
                "url": "https://www.pathkindlabs.com/api/v1/home-collection-booking/register",
                "params": {
                    "name": jsonData.params.name,
                    "mobile": jsonData.params.mobile,
                    "city_id": 1,
                    "ci_csrf_token": "",
                }
            }
            var webformid = jsonData.params.form_id;
            var raw = data.params;
            var settings = {
                "url": data.url,
                "method": "POST",
                "headers": {
                    "Content-Type": "application/x-www-form-urlencoded",
                },
                "data": raw
            };
            $.ajax(settings).done(function (response) {
                console.log('jsonData', jsonData);
                var res = response;
                if (res.status) {
                    redirectUrl = thankyouPageUrl[webformid] + '?token=' + res.data.token + '&city=' + jsonData.params.city;
                    var UTM_Source = findGetParameter('utm_source');
                    var UTM_Medium = findGetParameter('utm_medium');
                    var CampaignID = findGetParameter('utm_campaign');

                    if (findGetParameter('search+city') || findGetParameter('test_location_id')) {
                        var UTM_Source = 'Ecom';
                        var UTM_Medium = 'Website Form';
                        var CampaignID = 'City';
                    }
                    if (findGetParameter('token')) {
                        var UTM_Source = 'Ecom';
                        var UTM_Medium = 'Website Form';
                        var CampaignID = 'Not Available';
                    }
                    if (findGetParameter('vid')) {
                        var UTM_Source = 'Ecom';
                        var UTM_Medium = 'Website Form';
                        var CampaignID = 'Not Available';
                    }

                    var campaignData = {
                        "url": "https://www.pathkindlabs.com/auth/webform/submit",
                        "params": {
                            "Name": jsonData.params.name,
                            "MobileNo": jsonData.params.mobile,
                            "City": jsonData.params.city,
                            "whatsapp_status": jsonData.params.whatsapp_status,
                            "UTM_Source": UTM_Source ? UTM_Source : 'Organic',
                            "UTM_Medium": UTM_Medium ? UTM_Medium : 'Website Form',
                            "CampaignID": CampaignID ? CampaignID : 'Home Page',
                            "LeadUrl": window.location.href,
                            "CampaignName": '',
                            "ci_csrf_token": "",
                        }
                    }
                    sendAjax(e, campaignData, webformid, redirectUrl);
                } else {
                    $(e).prepend(`<div class="error-alert" id="msg-alert">Something went wrong try again.</div>`);
                    $('html, body').animate({
                        scrollTop: $(e).offset().top - 200
                    }, 1000);
                }
            }).fail(function (errorobj, textstatus, error) {
                erroHandling(errorobj, textstatus, error);
            });;
        } else {
            console.log('error 1');
        }
    }

  async function sendAjax(e, data, webformid = null, directRedirectUrl = null, apiResponse = null) {
    if (e && data.url && (data.params.MobileNo || data.params.mobile)) {
        var raw = data.params;
        const payload = {
            body: raw,
            url: data.url,
            authorization: apiResponse?.authorization_token
        }
        const headerData = generateHeaders(payload);
        headers = {};
        headers["Content-Type"] = "application/x-www-form-urlencoded";
        headers[`x${_api_token}`] = headerData[`x${_api_token}`];
        headers[`auth${_nonce}`] = headerData[`auth${_nonce}`];
        headers[`auth${_signature}`] = headerData[`auth${_signature}`];
        headers[`authorization`] = apiResponse?.authorization_token;

        try {
            // 🔑 Wait for encrypted mobile
            let encrypted = await getEncryptedMobile(data.params.MobileNo);
            console.log("Final Encrypted:", encrypted);

            if (!encrypted) {
                console.error("Encryption failed. Skipping WebEngage login.");
            }

            var settings = {
                "url": data.url,
                "method": "POST",
                "headers": headers,
                "data": raw
            };

            $.ajax(settings).done(async function (response) {
                var res = JSON.parse(response); 
                let trackerPageName = formIdByPageNameWithPageUrl[webformid];

                // 🔑 Use encrypted mobile here
                if (encrypted) {
                    webengage.user.login(encrypted);
                }

                if (data.params.Email) {
                    webengage.user.setAttribute('we_email', data.params.Email);
                }
                webengage.user.setAttribute('we_phone', '+91' + data.params.MobileNo);
                webengage.user.setAttribute('we_first_name', data.params.Name);
                webengage.user.setAttribute('we_whatsapp_opt_in', (data.params.whatsapp_status == 1) ? true : false);

                var form_id = $('#otpFormSubmit').find('input[name="form_id"]').val();
                if (form_id == "upload-prescription") {
                    webengage.track('Prescription Uploaded', {
                        Name: data.params.Name,  
                        Phone: '+91' + data.params.MobileNo,
                        City: data.params.City,
                        Email: data.params.Email,
                        ///File : $('input[name=valid_prescription_path]').val(),
                        File: $('input[name=valid_prescription_path]').val() ? true : false,
                        WhatsappOption : data.params.whatsapp_status,
                        Page_Name: webformid,
                        Page_url: window.location.href,
                    }); 
                } else {
                    webengage.track(trackerPageName, {
                        Name: data.params.Name,  
                        Phone: '+91' + data.params.MobileNo,
                        City: data.params.City,
                        Email: data.params.Email,
                        WhatsappOption : data.params.whatsapp_status,
                        Page_Name: webformid,
                        Page_url: window.location.href 
                    }); 
                }

                // redirect handling remains same
                if (res.status) {
                    if (directRedirectUrl) {
                        location.href = 'https://www.pathkindlabs.com/' + directRedirectUrl;
                        return;
                    }
                    redirectUrl = thankyouPageUrl[webformid];
                    if (redirectUrl) {
                        location.href = 'https://www.pathkindlabs.com/' + redirectUrl;
                    } else {
                        clearForms();
                        let trackerPageName = formIdByPageNameWithPageUrl[webformid];
                        webengage.track(trackerPageName, {
                            Name: data.params.Name,  
                            Phone: '+91' + data.params.MobileNo,
                            City: data.params.City,
                            Email: data.params.Email,
                            WhatsappOption : data.params.whatsapp_status,
                            Page_Name: webformid,
                            Page_url: window.location.href
                        });  
                        $('#otpFormSubmit,#without-otp,#drivThruForm').prepend(`<div class="alert success-alert" id="msg-alert" role="alert">Your request has been sent successfully.</div>`);
                        $('.success-alert').fadeOut(5000);
                        $('html, body').animate({
                            scrollTop: $(e).offset().top - 200
                        }, 1000);
                    }
                } else {
                    let msg = res.message ? res.message : 'Something went wrong try again.';
                    $('#otpFormSubmit,#without-otp,#drivThruForm').prepend(`<div class="alert error-alert" id="msg-alert" role="alert">${msg}</div>`);
                    $('html, body').animate({
                        scrollTop: $(e).offset().top - 200
                    }, 1000);
                }
            }).fail(function (errorobj, textstatus, error) {
                clearForms();
                console.log(errorobj, textstatus, error);
                erroHandling(errorobj, textstatus, error);
            });
        } catch (err) {
            console.error("Error during encryption or WebEngage:", err);
        }
    } else {
        console.log('error 1');
        $('#otpFormSubmit,#without-otp,#drivThruForm').prepend(`<div class="error-alert" id="msg-alert">Enter your mobile number.</div>`);
        $('html, body').animate({
            scrollTop: $(e).offset().top - 200
        }, 1000);
    }
}


    function clearForms() {
        $('#verifyOtp').fadeOut(0);
        $('#otpFormSubmit').fadeIn(0);
        $('input[name="name"]').val('');
        $('input[name="mobile_no"]').val('');
        $('input[name="city"]').val('');
        $('input[name="current_address"]').val('');
        $('input[name="email"]').val('');
        $('input[name="date_of_birth"]').val('');
        $('input[name="patient_name"]').val('');
        $('input[name="drive_thru_in"]').val('');
        $('input[name="valid_id_proof"]').val('');
        $('.valid_id_proof_path').remove();
        $('input[name="valid_id_proof"]').val('');
        $('input[name="valid_address_proof"]').val('');
        $('.valid_id_proof_path').remove();
        $('.valid_address_proof_path').remove();
        setTimeout(function () {
            // window.location.reload();
        }, 3000);
    }

    function validateForms(e) {
        var flag = false;
        var firstInput = '';
        var inputs = $(e).find('input');
        var selectInputs = $(e).find('select');
        Array.prototype.push.apply(inputs, selectInputs);
        var err = $('.error-class');
        err.remove();

        inputs.map(function (data, index) {
            var hasAttr = $(this).attr('isrequired');
            var val = $(this).val();
            if ($(this).attr('name'))
                var NameAttr = $(this).attr('name').toLowerCase();
            else
                var NameAttr = '';
            if (hasAttr) {
                if (!val && (NameAttr != 'otp' || NameAttr != 'otp[]')) {
                    if (!firstInput)
                        firstInput = this;
                    $(this).after('<div class="error-class">This field is required.</div>');
                    flag = true;
                }
                // if (NameAttr == 'email_id') {
                //     if (!checkEmail($(this).val()) && val != '') {
                //         if (!firstInput)
                //             firstInput = this;
                //         if ($(this).nextAll().length > 0) {
                //             $(this).nextAll().after('<div class="error-class">Enter valid email.</div>');
                //         } else {
                //             $(this).after('<div class="error-class">Enter valid email.</div>');
                //         }
                //         flag = true;
                //     }
                // }
                if (NameAttr == 'captcha_response') {
                    var captcha = '';
                    if ($(this).val() && val != captcha) {
                        if (!firstInput)
                            firstInput = this;
                        if ($(this).nextAll().length > 0) {
                            $(this).nextAll().after('<div class="error-class">Captcha verification failed.</div>');
                        } else {
                            $(this).after('<div class="error-class">Captcha verification failed.</div>');
                        }
                        flag = true;
                    }
                }
                if (NameAttr == 'mobile' || NameAttr == 'mobile_no' || NameAttr == 'mobileNo') {
                    if ($(this).val().length != 10 && val != '') {
                        if (!firstInput)
                            firstInput = this;
                        if ($(this).nextAll().length > 0) {
                            $(this).nextAll().after('<div class="error-class">Mobile no should be of 10 numerical digits</div>');
                        } else {
                            $(this).after('<div class="error-class">Mobile no should be of 10 numerical digits</div>');
                        }
                        flag = true;
                        //  $(this).focus();
                    }
                }
            }
        });
        if (flag) {
            if (firstInput)
                $(firstInput).focus();
            return false;
        } else {
            return true;
        }
    };

    function findGetParameter(parameterName) {
        var result = null,
            tmp = [];
        location.search
            .substr(1)
            .split("&")
            .forEach(function (item) {
                tmp = item.split("=");
                if (tmp[0] === parameterName)
                    result = decodeURIComponent(tmp[1]);
            });
        return result;
    }
    // $('.otp-in').keyup(function() {
    //     this.value = this.value.replace(/[^0-9]/g, '').replace(/(\..*)\./g, '$1');
    // });
    $('.otp-in,.otp-block').keyup(function () {
        var val = $(this).val();
        var valLength = val.length;
        if (val) {
            this.value = this.value.replace(/[^0-9]/g, '').replace(/(\..*)\./g, '$1');

            $(this).val(val[valLength - 1]);
            $(this).parent('.otp-input').next().find('input').focus();
            $(this).next().focus();
        }
    });

    function erroHandling(jqXHR, error, errorThrown) {
        // console.log(jqXHR, error, errorThrown);
        var message;
        var statusErrorMap = {
            '0': "You are offline, check your connectivity.",
            '400': "Server understood the request, but request content was invalid.",
            '401': "Unauthorized access.",
            '403': "Forbidden resource can't be accessed.",
            '500': "Internal server error.",
            '502': "502 Bad Gateway.",
            '503': "Service unavailable."
        };
        if (jqXHR.status == 403) {
            window.location.reload();
            return;
        }
        if (jqXHR.status) {
            message = statusErrorMap[jqXHR.status];
            if (!message) {
                message = "Unknown Error \n.";
            }
        } else if (errorThrown == 'parsererror') {
            message = "Error.\nParsing JSON Request failed.";
        } else if (errorThrown == 'timeout') {
            message = "Request Time out.";
        } else if (errorThrown == 'abort') {
            message = "Request was aborted by the server";
        } else {
            message = statusErrorMap[jqXHR.status];
        }
        $('#otpFormSubmit,#without-otp').prepend(`<div class="error-alert" id="msg-alert">` + message + `</div>`);
        $('html, body').animate({
            scrollTop: $(e).offset().top - 200
        }, 1000);
        // alert(message);
    }

