<script>
document.addEventListener("DOMContentLoaded", function () {
  const totalRow = document.querySelector(".total-row");
  const totalEl = document.querySelector("._grand_Total");

  if (!totalRow || !totalEl) return;

  const updateTotalVisibility = () => {
    const total = parseFloat(totalEl.getAttribute("data-gtotal")) || 0;
    totalRow.style.display = total > 0 ? "flex" : "none";
  };

  // Initial check
  updateTotalVisibility();

  // Watch for dynamic updates
  new MutationObserver(updateTotalVisibility).observe(totalEl, {
    attributes: true,
    attributeFilter: ["data-gtotal"]
  });
});
</script>

