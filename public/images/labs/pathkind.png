  <!-- Justified Gallery CSS & JS -->


  <script defer src="https://cdn.jsdelivr.net/npm/justifiedGallery@3.8.1/dist/js/jquery.justifiedGallery.min.js"></script>

  <!-- Fancybox CSS & JS -->
  <script defer src="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox.umd.js"></script>
<script>
    $(document).ready(function () {
      const images = [
        "g1s.jpg", "g2.jpg", "g3s.png", "g4.jpg", "g5.jpg", "g6.jpg",
        "g7.jpg", "g8.jpg", "g9.jpg", "g10.jpg", "g11.jpg", "g12.jpg",
        "g13.jpg", "g14.jpg", "g15.jpg","gpn.jpeg", "gpn1.jpeg"
      ];
      const baseURL = "https://pathkindlabs.com/assets/img/";
      const imagesPerPage = 6;
      let currentPage = 0;

      function renderGallery() {
        const start = currentPage * imagesPerPage;
        const end = start + imagesPerPage;
        const gallery = $("#my-gallery");
        gallery.empty();

        const pageImages = images.slice(start, end);
        for (const img of pageImages) {
          const fullPath = baseURL + img;
          gallery.append(`<a href="${fullPath}" data-fancybox="gallery"><img src="${fullPath}" alt=""></a>`);
        }

        gallery.justifiedGallery({
          rowHeight: 200,
          margins: 5,
          lastRow: 'justify',
          captions: false
        }).on('jg.complete', function () {
          Fancybox.bind('[data-fancybox="gallery"]', {
            groupAll: true
          });
        });

        $("#prev-btn").prop('disabled', currentPage === 0);
        $("#next-btn").prop('disabled', end >= images.length);
      }

      $("#prev-btn").click(function () {
        if (currentPage > 0) {
          currentPage--;
          renderGallery();
        }
      });

      $("#next-btn").click(function () {
        if ((currentPage + 1) * imagesPerPage < images.length) {
          currentPage++;
          renderGallery();
        }
      });

      renderGallery();
    });


  </script>

