                    "CampaignName": '',
                    "ci_csrf_token": "",
                }
            }
            sendAjax(e, campaignData, webformid, redirectUrl,response);
        } else if (data.params.form_id == 'franchise-business-opportunities' || data.params.form_id == 'annual-corporate-wellness-program' || data.params.form_id == 'hospital-lab-management' || data.params.form_id == 'organise-free-health-check-up-camps' || data.params.form_id == 'health-checkups-sp' || data.params.form_id == 'health-checkups-af' || data.params.form_id == 'radiology' || data.params.form_id == 'health-packages' || data.params.form_id == 'nabl' || data.params.form_id == 'know-about-covid-19' || data.params.form_id == 'book-home-collection'|| data.params.form_id == 'contact-us') {
            // console.log('testiiiiiiiiiiii');
            var webformid = data.params.form_id;
            var campaignData = {
                "headers": headers,
                "url": "https://www.pathkindlabs.com/auth/webform/submit",
                "params": {
                    "Name": data.params.name,
                    "MobileNo": data.params.mobile,
                    "City": data.params.city,
                    "Email": data.params.email,
                    "whatsapp_status": data.params.whatsapp_status,
                    "UTM_Source": findGetParameter('utm_source'),
                    "UTM_Medium": findGetParameter('utm_medium'),
                    "CampaignID": findGetParameter('utm_campaign'),
                    "LeadUrl": window.location.href,
                    "CampaignName": '',
                    "ci_csrf_token": "",
                }
            }
            console.log(campaignData);
            sendAjax(e, campaignData, webformid,'',response);
        }
    }
