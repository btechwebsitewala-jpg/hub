                            </div>
                            <div class="otp-input">
                                <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                            </div>
                            <div class="otp-input">
                                <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                            </div>
                            <div class="otp-input">
                                <input type="text" name="otp[]" class="width-set number otp-in" maxlength="1">
                            </div>
                        </div>
                        <div class="otp_error"></div>
                        <div class="otpgrop">
                            <button type="submit" class="next-btn" id="submitBookingOTP_track">
                                Verify and Proceed
                            </button>
                            <span class="_resent_otp resend-otp-link_track" style="display:none; cursor: pointer;" onclick="resendVerifyOtpDivTrack();">Resend OTP</span>
