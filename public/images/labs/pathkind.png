  <script>
  $("#radiologyCity, #city, #TestCity, #cityss, #_city__").select2({
    placeholder: "Select Your City",
    allowClear: true,
    matcher: function(params, data) {
      // Agar search box empty hai to sab dikhao
      if ($.trim(params.term) === '') {
        return data;
      }

      // Match starting letters only
      if (data.text.toLowerCase().startsWith(params.term.toLowerCase())) {
        return data;
      }

      // Otherwise no match
      return null;
    }
  });
</script>
