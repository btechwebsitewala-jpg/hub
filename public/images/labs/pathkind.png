</script>
<script>
    function startTimer() {

        var presentTime = $("#_sstimer_id_").text();
        var timeArray = presentTime.split(/[:]+/);
        var m = timeArray[0];
        var s = checkSecond((timeArray[1] - 1));
        var timeout;
        if (s == 59) {
            m = m - 1
        }
        if (m < 0) {
            $("#_sstimer_id_").prop("id", "stop-timer");
            $(".resend-otp-text").hide();
            $(".resend-otp-link").show();
        }
        console.log(presentTime);
        $("#_sstimer_id_").html(m + ":" + s);
        timeout = setTimeout(startTimer, 1000);
        // var presentTime = $("#timer_id_").text().trim();
        // console.log(presentTime);
        // var timeArray = presentTime.split(/[:]+/);
        // var m = parseInt(timeArray[0]);
        // var s = parseInt(timeArray[1]);

        // // Reduce seconds, and check if we need to decrement minutes
        // s = s - 1;
        // if (s < 0) {
        //     s = 59;
        //     m = m - 1;
        // }

        // if (m < 0) {
        //     $("#timer_id_").prop("id", "stop-timer");
        //     $(".resend-otp-text").hide();
        //     $(".resend-otp-link").show();
        // } else {
        //     $("#timer_id_").html(m + ":" + (s < 10 ? '0' + s : s));  // Formatting seconds with leading 0
        //     setTimeout(startTimer, 1000);  // Recursive call
        // }
    }


    function checkSecond(sec) {
        if (sec < 10 && sec >= 0) {
            sec = "0" + sec
        };
        if (sec < 0) {
            sec = "59"
        };
        return sec;
    }

    
    


    $("#verify-otp-form").submit(function (event) {

        event.preventDefault();
        const form = $(this);
        postForm(form, "https://www.pathkindlabs.com/", "book-a-test/" + slugCityName);
        return false;
    });


    function postForm(form, redirect, callExternal = false) {
        console.log(form);
        var otp = $('.login-card').find('input[name="otp[]"]');
        var otpArr = [];
        var otpError = false
        if (otp.length == 6) {
            otp.each(function (index, data) {

                var oV = $(this).val();
                if (!oV) {
                    otpError = true;
                }
                otpArr.push(oV);
            });
        }
        otp = otpArr.join();
        otp = otp.replace(/,/g, '');
        var values = form.serializeArray();
        values.push({
            name: "otp",
            value: otp
        });
        values = jQuery.param(values);
        if (!otp && otp.length != 6) {
            $('#verify-otp-form').find(".form-error").html('<div class="error-class">Enter OTP.</div>');
            return;
        }
        const submitBtn = $('button[type="submit"]');
        submitBtn.prop("disabled", "disabled");
        $.ajax({
            url: form.attr("action"),
            type: "POST",
            dataType: "json",
            // data: form.serialize(),
            data: values,
            success: function (response) {
                // alert();
                response = JSON.parse(response);
                console.log(response);
                $('input[name="ci_csrf_token"]').val(response.csrfToken);

                if (response.status === 200 || response.status === 201) {

                    /**
                     * get User Info
                     * 
                     */
                    var userToken = response.data.user_token;
                    var CUSTOMERID = response.data.user_id;
                    var CUSTOMERMOBILE = response.data.mobile;
                    var authorization_token = response.data.authorization_token;
                    setCookie("user_token", userToken, 365);
                    setCookie("CUSTOMERID", CUSTOMERID, 365);
                    setCookie("CUSTOMERMOBILE", CUSTOMERMOBILE, 365);
                    setCookie("authorization_token", authorization_token, 365);
                    callExternal = 'https://www.pathkindlabs.com/theme/assets/images/logo.png';
                    var download_reports = findGetParameter('dr');
                    // return false;
                    if (download_reports) {
                        setTimeout(() => {
                            window.location = 'https://www.pathkindlabs.com/my-account/download-reports';
                        }, 500);
                    } else {
                        if (callExternal) {
                            setTimeout(function () {
                                window.location.href = `${callExternal}?token=${response.data.token}&url=${redirect}`;
                            }, 500);
                        } else {
                            // console.log(2);
                            setTimeout(function () {
                                window.location.href = redirect;
                            }, 500);
                            submitBtn.removeAttr("disabled");
                        }
                    }


                } else {
                    $("#verify-otp-form").find(".form-error").html('<div class="error_class">Invalid OTP.</div>');
                    submitBtn.removeAttr("disabled");

                }
            }
        });
    }
    // function setCookie(cname, cvalue, exdays) {
    //     var d = new Date();
    //     d.setTime(d.getTime() + (exdays*24*60*60*1000));
    //     var expires = "expires="+ d.toUTCString();
    //     document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
    // }
</script>
<script>

    jQuery(window).on("scroll", onScroll);

    function onScroll(event) {
        var scrollPos = jQuery(document).scrollTop();
        jQuery("#menu-center a").each(function () {
            var currLink = jQuery(this);
            var refElement = jQuery(currLink.attr("href"));
            if (
                refElement.offset().top - 200 <= scrollPos &&
                refElement.offset().top + refElement.height() > scrollPos
            ) {
                jQuery("#menu-center ul li a").removeClass("current");
                currLink.addClass("current");
            } else {
                currLink.removeClass("current");
            }
        });
    }

    jQuery(".tab-row a").each(function () {
        jQuery(this).on("click", function (event) {
            event.preventDefault();
            var currentId = jQuery(this).attr("href");
            setTimeout(() => {
                jQuery("html, body").animate(
                    {
                        scrollTop: jQuery(currentId).offset().top - 50
                    },
                    0
                );
            }, 0);
        });
    });

    function franchiseFormSubmit() {
        var inValidNumber = [
            '777777777',
            '6666666666',
            '888888888',
            '999999999'
        ];
        $('.error-class').remove();
        var name = $('input[name=name1]');
        var mobile = $('input[name=mobile_no1]');
        var email = $('input[name=email1]');
        var city = $('input[name=city1]');
        var whatsapp_status = $('input[name=whatsapp_status1]').is(":checked") ? 1 : 0;
        if (!name.val()) {
            $(name).after('<div class="error-class">Enter your name.</div>');
            return false;
        } else {
            name = name.val();
        }
        if (!mobile.val()) {
            $(mobile).after('<div class="error-class">Enter your mobile.</div>');
            return false;
        } else {
            if (inValidNumber.includes(mobile.val())) {
                $(mobile).after('<div class="error-class">Enter your valid mobile.</div>');
                return false;
            } else {
                mobile = mobile.val();

            }
        }
        if (!city.val()) {
            $(city).after('<div class="error-class">Select your city.</div>');
            return false;
        } else {
            city = city.val();
        }
        if (!email.val()) {
            $(mobile).after('<div class="error-class">Enter your Email.</div>');
            return false;
        } else {
            email = email.val();
        }

        $('#franchise2').prop('disabled', true);
        $('#franchise2').attr('type', 'button');
        createBooking(name, mobile, email, city, whatsapp_status);

    }

    function createBooking(name, mobile, email, city, whatsapp_status) {
        // debugger;
        var settings1 = {
            "url": "https://www.pathkindlabs.com/auth/webform/submit",
            "method": "POST",
            "timeout": 0,
            "data": {
                "Name": name,
                "MobileNo": mobile,
                "Email": email,
                "City": city,
                "whatsapp_status": whatsapp_status,
                "UTM_Source": findGetParameter('utm_source'),
                "UTM_Medium": findGetParameter('utm_medium'),
                "CampaignID": findGetParameter('utm_campaign'),
                "LeadUrl": window.location.href,
                "CampaignName": '',
                "ci_csrf_token": "",
            },
        };
        console.log(settings1);
        $.ajax(settings1).done(function (response) {
            if (response) {
                console.log(response);
                response = JSON.parse(response);
                if (response.status == true) {

                    // setTimeout(function() {
                    location.href = 'thank-you';
                    // }, 500);
                }
                else {
                    $('#franchise2').prop('disabled', false);
                    $('#franchise2').attr('type', 'submit');
                }
            } else {
                $('#franchise2').prop('disabled', false);
                $('#franchise2').attr('type', 'submit');
            }
        });
    }
</script>  
