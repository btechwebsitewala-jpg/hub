/**
 * Sidebar menu Open & Close
 */
$(document).ready(function () {
  $('.sidebar-menu').on('click', function () {
    var $this = $(this);
    var $submenu = $this.next('.sub-menu');

    if ($this.hasClass('open')) {
      // If already open, close it
      $this.removeClass('open');
      $this.find('.expand').removeClass('turn');
      $submenu.removeClass('open').hide();
    } else {
      // Close any open ones
      $('.sidebar-menu').removeClass('open');
      $('.sub-menu').removeClass('open').hide();
      $('.sidebar-menu .expand').removeClass('turn');

      // Open current
      $this.addClass('open');
      $this.find('.expand').addClass('turn');
      $submenu.addClass('open').show();
    }
  });

  // Optional hover behavior
  $('.sidebar-menu').mouseenter(function () {
    $(this).find('.expand').addClass('turn');
  });

  $('.sidebar-menu').mouseleave(function () {
    if (!$(this).hasClass('open')) {
      $(this).find('.expand').removeClass('turn');
    }
  });
});


